{
  "enabledPlugins": {
    "oh-my-claudecode@omc": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/quantmind-v2/.claude/hooks/session_context_inject.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/quantmind-v2/.claude/hooks/pre_commit_validate.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python D:/quantmind-v2/.claude/hooks/redline_pretool_block.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/quantmind-v2/.claude/hooks/protect_critical_files.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python D:/quantmind-v2/.claude/hooks/iron_law_enforce.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python D:/quantmind-v2/.claude/hooks/cite_drift_stop_pretool.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Program Files/Git/bin/bash.exe C:/Users/hd/.claude/plugins/marketplaces/everything-claude-code/skills/continuous-learning-v2/hooks/observe.sh pre",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/quantmind-v2/.claude/hooks/post_edit_lint.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/quantmind-v2/.claude/hooks/audit_log.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "C:/Program Files/Git/bin/bash.exe C:/Users/hd/.claude/plugins/marketplaces/everything-claude-code/skills/continuous-learning-v2/hooks/observe.sh post",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/quantmind-v2/.claude/hooks/verify_completion.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
