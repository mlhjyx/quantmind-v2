{
  "Name": "QuantMind-Celery",
  "DisplayName": "QuantMind Celery Worker",
  "Description": "Celery worker (solo pool, queues: default,factor_calc,data_fetch)",
  "ExecutablePath": "D:\\quantmind-v2\\.venv\\Scripts\\python.exe",
  "StartupDirectory": "D:\\quantmind-v2",
  "Parameters": "-m celery -A app.tasks.celery_app worker --pool=solo --concurrency=1 -Q default,factor_calc,data_fetch -n worker-main@%COMPUTERNAME%",
  "StartupType": 2,
  "Priority": 2,
  "StdoutPath": "D:\\quantmind-v2\\logs\\celery-stdout.log",
  "StderrPath": "D:\\quantmind-v2\\logs\\celery-stderr.log",
  "EnableRotation": true,
  "RotationSize": 100,
  "EnableDateRotation": false,
  "DateRotationType": 0,
  "MaxRotations": 5,
  "EnableHealthMonitoring": true,
  "HeartbeatInterval": 15,
  "MaxFailedChecks": 3,
  "RecoveryAction": 1,
  "MaxRestartAttempts": 5,
  "ServiceDependencies": "Redis",
  "RunAsLocalSystem": true,
  "PreLaunchTimeoutSeconds": 30,
  "PreLaunchRetryAttempts": 0,
  "PreLaunchIgnoreFailure": false,
  "EnableDebugLogs": false,
  "StartTimeout": 15,
  "StopTimeout": 30,
  "PreviousStopTimeout": 30,
  "ActiveStdoutPath": "D:\\quantmind-v2\\logs\\celery-stdout.log",
  "ActiveStderrPath": "D:\\quantmind-v2\\logs\\celery-stderr.log",
  "PreStopTimeoutSeconds": 5,
  "PreStopLogAsError": false
}