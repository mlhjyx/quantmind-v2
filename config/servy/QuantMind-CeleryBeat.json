{
  "Name": "QuantMind-CeleryBeat",
  "DisplayName": "QuantMind Celery Beat",
  "Description": "Celery beat scheduler for periodic tasks",
  "ExecutablePath": "D:\\quantmind-v2\\.venv\\Scripts\\python.exe",
  "StartupDirectory": "D:\\quantmind-v2",
  "Parameters": "-m celery -A app.tasks.celery_app beat --loglevel=info",
  "StartupType": 2,
  "Priority": 2,
  "StdoutPath": "D:\\quantmind-v2\\logs\\celery-beat-stdout.log",
  "StderrPath": "D:\\quantmind-v2\\logs\\celery-beat-stderr.log",
  "EnableRotation": true,
  "RotationSize": 50,
  "EnableDateRotation": false,
  "DateRotationType": 0,
  "MaxRotations": 3,
  "EnableHealthMonitoring": true,
  "HeartbeatInterval": 30,
  "MaxFailedChecks": 3,
  "RecoveryAction": 1,
  "MaxRestartAttempts": 5,
  "ServiceDependencies": "Redis; QuantMind-Celery",
  "RunAsLocalSystem": true,
  "PreLaunchTimeoutSeconds": 30,
  "PreLaunchRetryAttempts": 0,
  "PreLaunchIgnoreFailure": false,
  "EnableDebugLogs": false,
  "StartTimeout": 10,
  "StopTimeout": 10,
  "PreviousStopTimeout": 10,
  "ActiveStdoutPath": "D:\\quantmind-v2\\logs\\celery-beat-stdout.log",
  "ActiveStderrPath": "D:\\quantmind-v2\\logs\\celery-beat-stderr.log",
  "PreStopTimeoutSeconds": 5,
  "PreStopLogAsError": false
}