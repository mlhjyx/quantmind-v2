  "StartTimeout": 30,
  "StopTimeout": 15,
  "PreviousStopTimeout": 15,
  "ActiveStdoutPath": "D:\\quantmind-v2\\logs\\qmt-data-stdout.log",
  "ActiveStderrPath": "D:\\quantmind-v2\\logs\\qmt-data-stderr.log",
