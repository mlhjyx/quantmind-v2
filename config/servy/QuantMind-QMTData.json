{
  "Name": "QuantMind-QMTData",
  "DisplayName": "QuantMind QMT Data Service",
  "Description": "QMT data sync: positions/prices to Redis cache every 60s",
  "ExecutablePath": "D:\\quantmind-v2\\.venv\\Scripts\\python.exe",
  "StartupDirectory": "D:\\quantmind-v2",
  "Parameters": "D:\\quantmind-v2\\scripts\\qmt_data_service.py",
  "StartupType": 2,
  "Priority": 2,
  "StdoutPath": "D:\\quantmind-v2\\logs\\qmt-data-stdout.log",
