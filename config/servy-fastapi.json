{
  "Name": "QuantMind-FastAPI",
  "DisplayName": "QuantMind FastAPI Server",
  "Description": "QuantMind V2 backend API (uvicorn --workers 2)",
  "ExecutablePath": "D:\\quantmind-v2\\.venv\\Scripts\\python.exe",
  "StartupDirectory": "D:\\quantmind-v2\\backend",
  "Parameters": "-m uvicorn app.main:app --host=0.0.0.0 --port=8000 --workers=2",
  "StartupType": 2,
  "Priority": 2,
  "StdoutPath": "D:\\quantmind-v2\\logs\\fastapi-stdout.log",
  "StderrPath": "D:\\quantmind-v2\\logs\\fastapi-stderr.log",
  "EnableRotation": true,
  "RotationSize": 100,
  "EnableDateRotation": false,
  "DateRotationType": 0,
  "MaxRotations": 5,
  "EnableHealthMonitoring": true,
  "HeartbeatInterval": 15,
  "MaxFailedChecks": 3,
  "RecoveryAction": 1,
  "MaxRestartAttempts": 5,
  "ServiceDependencies": "Redis; PostgreSQL16",
  "RunAsLocalSystem": true,
  "PreLaunchTimeoutSeconds": 30,
  "PreLaunchRetryAttempts": 0,
  "PreLaunchIgnoreFailure": false,
  "EnableDebugLogs": false,
  "StartTimeout": 30,
  "StopTimeout": 15,
  "PreviousStopTimeout": 15,
  "ActiveStdoutPath": "D:\\quantmind-v2\\logs\\fastapi-stdout.log",
  "ActiveStderrPath": "D:\\quantmind-v2\\logs\\fastapi-stderr.log",
  "PreStopTimeoutSeconds": 5,
  "PreStopLogAsError": false
}