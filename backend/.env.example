# === 数据库 ===
# 复制本文件为 backend/.env 并填入真实值。切勿提交 backend/.env 到 git。
DATABASE_URL=postgresql+asyncpg://xin:your_db_password_here@localhost:5432/quantmind_v2
REDIS_URL=redis://localhost:6379/0

# === 数据源 ===
# Tushare Pro: https://tushare.pro/user/token
TUSHARE_TOKEN=your_tushare_token_here

# === AI ===
# DeepSeek: https://platform.deepseek.com/api_keys
# 同一 key 经 LiteLLM 路由分别走 deepseek-v4-flash (deepseek-chat) / deepseek-v4-pro (deepseek-reasoner).
# 详 config/litellm_router.yaml + ADR-031 + V3 §5.5.
DEEPSEEK_API_KEY=sk-xxx

# === News ingestion (V3 §3.1, ADR-033 + ADR-035) ===
# 智谱 GLM-4.7-Flash News#1 fetcher (永久免费, ~1M tokens/天 + 200K context + OpenAI 兼容).
# Console: https://open.bigmodel.cn (注册后 → API Keys → 创建).
# 详 ADR-035 §2 (V4 路由层 0 智谱, 走 News ingestion 层独立 client) + V3 §3.1.
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Tavily News#2 fetcher (英文 + 翻译 海外信号, 1000 credits/月永久免费).
# Console: https://app.tavily.com (注册后 → API Keys → 创建).
# 详 V3 §3.1 + ADR-033 (News 6 源换源决议) + sub-PR 2 sediment.
TAVILY_API_KEY=your-tavily-api-key-here
TAVILY_BASE_URL=https://api.tavily.com

# Anspire 安思派 News#3 fetcher (中文财经主源, 新户 2500 点免费 + 即时注册).
# Console: https://open.anspire.cn (注册后 → API Keys → 创建).
# 详 V3 §3.1 + ADR-033 (News 6 源换源决议) + sub-PR 3 sediment.
# Anspire-specific finding (5-06 Phase 1 fresh verify): GET method (反 POST) /
# query 64 char hard limit / top_k enum 10/20/30/40/50 / `date` field in response.
ANSPIRE_API_KEY=your-anspire-api-key-here
ANSPIRE_BASE_URL=https://plugin.anspire.cn

# GDELT 2.0 News#4 fetcher (全球事件 + 跨境 stream, 0 API key + 完全免费 + 7×24 实时).
# 0 console + 0 API key 申请 (anonymous access, V3§3.1 + ADR-035 §2 ground truth).
# 详 V3 §3.1 + ADR-033 (News 6 源换源决议) + sub-PR 4 sediment.
# GDELT-specific finding (5-06 Phase 1 fresh verify): GET method (沿用 Anspire) /
# 0 auth header / `articles` wrapper / `seendate` YYYYMMDDTHHMMSSZ format /
# `language` human-readable ("English"/"Chinese") / MAXRECORDS clamp [1, 250].
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc

# Marketaux News#5 fetcher (金融信号 + sentiment 标签, 100 req/day 免费 + 5000+ sources / 30+ languages).
# Console: https://www.marketaux.com (注册后 → Account → API Token).
# 详 V3 §3.1 + ADR-033 (News 6 源换源决议, 5-06 修订) + sub-PR 5 sediment.
# Marketaux-specific finding (5-06 Phase 1 fresh verify): api_token query param
# (反 Bearer header) / Custom User-Agent header required (反 default UA → Cloudflare
# 1010 block) / `data` array wrapper / `language` ISO code / `published_at` ISO 8601
# microseconds + Z / 0 sentiment_score by default (sentiment_min filter 留 sub-PR 7).
MARKETAUX_API_KEY=your-marketaux-api-key-here
MARKETAUX_BASE_URL=https://api.marketaux.com

# LLM 月度预算守门 (V3 §20.1 #6 + ADR-031, S2.2 sediment, PR #223).
# BudgetGuard 走 monthly_budget × warn / cap 阈值, capped 时强制 Ollama fallback.
# 调阈值无需改代码 (沿用铁律 34 Config SSOT, BaseSettings 自动 reload .env).
# LLM_MONTHLY_BUDGET_USD=50.0
# LLM_BUDGET_WARN_THRESHOLD=0.80
# LLM_BUDGET_CAP_THRESHOLD=1.00

# Ollama 本地 fallback (S3 sub-task 真依赖, 0 cost).
# LiteLLM Router 真预约 fallback path (DeepSeek 全 timeout 时切走).
# 默认本地 11434 端口 (Ollama 标准). LiteLLM ollama provider 内部自动拼接路径,
# 此处 base url 不加后缀 (Ollama 原生支持 OpenAI-compatible endpoint).
OLLAMA_BASE_URL=http://localhost:11434

# === miniQMT ===
QMT_PATH=E:\国金QMT交易端模拟\userdata_mini
QMT_ACCOUNT_ID=
QMT_ALWAYS_CONNECT=true

# === 执行模式 ===
EXECUTION_MODE=paper

# === 真金硬开关 (T1 sprint link-pause, 2026-04-29) ===
# 默认 true (fail-secure): MiniQMTBroker.place_order/cancel_order 直 raise
# LiveTradingDisabledError. paper_broker 物理隔离不受影响.
# 双因素 OVERRIDE bypass (紧急 manual 用):
#   LIVE_TRADING_FORCE_OVERRIDE=1
#   LIVE_TRADING_OVERRIDE_REASON='<explicit non-empty reason>'
# 推荐生产保持 true, 重启 PT live 前需显式改为 false.
# 撤销: docs/audit/link_paused_2026_04_29.md
LIVE_TRADING_DISABLED=true

# === 日志 ===
LOG_LEVEL=INFO
LOG_MAX_FILES=10

# === Paper Trading ===
PAPER_STRATEGY_ID=
PAPER_INITIAL_CAPITAL=1000000
# PT核心参数
PT_TOP_N=20
PT_INDUSTRY_CAP=1.0
PT_SIZE_NEUTRAL_BETA=0.50

# === 通知（可选） ===
# 钉钉机器人: https://open.dingtalk.com/document/robots/custom-robot-access
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your_token_here
# DINGTALK_SECRET=
# DINGTALK_KEYWORD=xin

# 批 2 P0 修 (2026-04-30) — DingTalk 双锁守门:
# DINGTALK_ALERTS_ENABLED=False default-off, 即使 webhook URL 配置仍不真发.
# True 时配合 alert_dedup TTL 去重才真发. 防 PR #150 36h spam 重演 + 5-5 周一前真生产风暴.
# DINGTALK_ALERTS_ENABLED=false
# DINGTALK_DEDUP_TTL_MIN=60
